diff --git a/firmware/esp32-csi-node/sdkconfig.defaults b/firmware/esp32-csi-node/sdkconfig.defaults
index 94ec092..db071b1 100644
--- a/firmware/esp32-csi-node/sdkconfig.defaults
+++ b/firmware/esp32-csi-node/sdkconfig.defaults
@@ -66,3 +66,16 @@ CONFIG_ESP_WIFI_EXTRA_IRAM_OPT=y
 # Was present in sdkconfig.defaults.template but missing here — fixed
 # in the v0.6.5-esp32 release.
 CONFIG_FREERTOS_TIMER_TASK_STACK_DEPTH=8192
+
+# Disable RM67162 AMOLED/LVGL (not present) so SSD1306 OLED can own I2C_NUM_0 via the new driver
+CONFIG_DISPLAY_ENABLE=n
+
+# Reboot the chip if a task hangs (default Task-WDT only warns). Lets a wedged
+# node self-heal instead of staying dead until a manual power-cycle — observed
+# on C5/C6 going silent overnight (no ping/ARP). Pairs with the app_main
+# connectivity watchdog (reboot on send stall) in main.c.
+CONFIG_ESP_TASK_WDT_PANIC=y
+# Task-WDT timeout 5s -> 15s: only a genuinely long hang triggers the panic
+# reboot. Transient bursts (WiFi reconnect, mmWave UART, CSI spikes) that briefly
+# exceed 5s no longer false-reboot otherwise-healthy nodes (S3s were churning).
+CONFIG_ESP_TASK_WDT_TIMEOUT_S=15
