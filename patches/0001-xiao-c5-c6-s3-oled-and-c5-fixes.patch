diff --git a/firmware/esp32-csi-node/main/edge_processing.c b/firmware/esp32-csi-node/main/edge_processing.c
index a92d040..de6e4ae 100644
--- a/firmware/esp32-csi-node/main/edge_processing.c
+++ b/firmware/esp32-csi-node/main/edge_processing.c
@@ -1420,7 +1420,9 @@ esp_err_t edge_processing_init(const edge_config_t *cfg)
     BaseType_t ret = xTaskCreatePinnedToCore(
         edge_task,
         "edge_dsp",
-        8192,       /* 8 KB stack — sufficient for DSP pipeline. */
+        16384,      /* 16 KB stack — pipeline uses ~6.5-7.5 KB and the compressed-
+                     * frame path adds two 1 KB buffers; 8 KB overflowed → CPU_LOCKUP
+                     * double-fault on ESP32-C5. Doubled for headroom (all targets). */
         NULL,
         5,          /* Priority 5 — above idle, below WiFi. */
         NULL,
@@ -1431,7 +1433,7 @@ esp_err_t edge_processing_init(const edge_config_t *cfg)
         return ESP_ERR_NO_MEM;
     }
 
-    ESP_LOGI(TAG, "Edge DSP task created on core %d (stack=8192, priority=5)",
+    ESP_LOGI(TAG, "Edge DSP task created on core %d (stack=16384, priority=5)",
              (int)dsp_core);
     return ESP_OK;
 }
