@@ -205,6 +216,20 @@ void app_main(void)
     /* Load runtime config (NVS overrides Kconfig defaults) */
     nvs_config_load(&g_nvs_config);
 
+#if defined(CONFIG_IDF_TARGET_ESP32C6)
+    /* XIAO ESP32-C6 antenna RF switch: GPIO14 LOW powers the switch on, GPIO3
+     * HIGH selects the external u.FL antenna (LOW = onboard ceramic). Better
+     * range/wall penetration — the external antenna MUST be physically attached
+     * or RF will be worse than the onboard one. Set before WiFi starts. */
+    gpio_reset_pin(GPIO_NUM_14);
+    gpio_set_direction(GPIO_NUM_14, GPIO_MODE_OUTPUT);
+    gpio_set_level(GPIO_NUM_14, 0);
+    gpio_reset_pin(GPIO_NUM_3);
+    gpio_set_direction(GPIO_NUM_3, GPIO_MODE_OUTPUT);
+    gpio_set_level(GPIO_NUM_3, 1);
+    ESP_LOGI(TAG, "C6 antenna switch -> external (u.FL)");
+#endif
+
     /* Capture node_id IMMEDIATELY — before wifi_init_sta() can corrupt
      * g_nvs_config. See #232/#375/#390: WiFi driver init clobbers the struct
      * on some devices, reverting node_id to the Kconfig default of 1. */
@@ -405,8 +430,28 @@ void app_main(void)
         }
     }
 
-    /* ADR-063: Initialize mmWave sensor (auto-detect on UART). */
-    esp_err_t mmwave_ret = mmwave_sensor_init(-1, -1);  /* -1 = use default GPIO pins */
+    /* ADR-063: Initialize mmWave sensor (auto-detect on UART).
+     * NOTE: the default mmWave UART pins are TX=17/RX=18. On ESP32-C5 those are
+     * the SPI flash pins (MSPI MISO=17, WP=18) — probing them reconfigures the
+     * flash data lines and corrupts code-fetch → "Illegal instruction" crash.
+     * C5 has no validated free default pins here and no mmWave sensor is wired,
+     * so skip the probe on C5. (S3/C6: 17/18 are ordinary GPIO, safe.) */
+#if defined(CONFIG_IDF_TARGET_ESP32C5)
+    esp_err_t mmwave_ret = ESP_ERR_NOT_SUPPORTED;
+    ESP_LOGI(TAG, "mmWave probe skipped on C5 (default pins 17/18 are flash pins)");
+#elif defined(CONFIG_IDF_TARGET_ESP32S3)
+    /* Seeed "24GHz mmWave for XIAO" = HLK-LD2410, wired on the XIAO S3 header
+     * D2/D3 = GPIO3/GPIO4. init(uart_tx_pin, uart_rx_pin); orientation verified
+     * empirically as MCU TX=GPIO4, RX=GPIO3 ((3,4) did NOT detect). A node with
+     * no radar wired probes and falls back to CSI-only gracefully. */
+    esp_err_t mmwave_ret = mmwave_sensor_init(4, 3);
+#else
+    /* Other targets (e.g. C6): no radar is wired and the default pins aren't the
+     * C6 D2/D3, so skip the probe entirely (S3-only mmWave). Avoids a pointless
+     * UART probe + log noise on every boot. */
+    esp_err_t mmwave_ret = ESP_ERR_NOT_SUPPORTED;
+    ESP_LOGI(TAG, "mmWave probe skipped (S3-only build target)");
+#endif
     if (mmwave_ret == ESP_OK) {
         mmwave_state_t mw;
         if (mmwave_sensor_get_state(&mw)) {
@@ -476,6 +521,10 @@ void app_main(void)
     }
 #endif
 
+    /* Seeed XIAO Expansion Board SSD1306 OLED (I2C, standalone). Probes 0x3C
+     * and no-ops if absent, so it is always safe to start. */
+    oled_task_start();
+
     /* RuView#893/#521: the MGMT-only promiscuous filter (set in
      * csi_collector_init as the #396 display-crash workaround) starves the CSI
      * callback on display-less boards — yield collapses to 0 pps and the node
@@ -500,8 +549,24 @@ void app_main(void)
              (swarm_ret == ESP_OK) ? g_nvs_config.seed_url : "off",
              (adapt_ret == ESP_OK) ? "on" : "off");
 
-    /* Main loop — keep alive */
+    /* Main loop — connectivity watchdog. Once the node has ever streamed, it
+     * reboots itself if sends stall too long (no-IP / wedged WiFi stack) so it
+     * self-heals overnight instead of staying dead until a manual power-cycle
+     * (observed: C5/C6 went silent ~2am and never came back). A full CPU/task
+     * hang is caught separately by the Task WDT (CONFIG_ESP_TASK_WDT_PANIC). */
+    const int64_t WDT_STALL_US = 240 * 1000000LL;  /* 240 s without a good send:
+        only reboot on a genuinely extended stall. A transient AP hiccup recovers
+        via the infinite WiFi-reconnect well within this, so we no longer reboot
+        the whole fleet in a cascade every time the router blips. */
     while (1) {
         vTaskDelay(pdMS_TO_TICKS(10000));
+        if (s_got_ip_once) {
+            int64_t last = stream_sender_last_ok_us();
+            if (last > 0 && (esp_timer_get_time() - last) > WDT_STALL_US) {
+                ESP_LOGE(TAG, "watchdog: no successful send for >%llds — restarting",
+                         (long long)(WDT_STALL_US / 1000000));
+                esp_restart();
+            }
+        }
     }
 }
